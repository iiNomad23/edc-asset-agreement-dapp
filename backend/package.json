{
  "name": "edc-asset-agreement-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "eslint .",
    "clean": "rimraf dist/* --glob",
    "maintenance:ncu:install": "npm install -g npm-check-updates",
    "maintenance:ncu": "ncu --enginesNode",
    "maintenance:ncu:u": "npm run maintenance:ncu -- --upgrade",
    "maintenance:ncu:minor": "npm run maintenance:ncu -- --target minor",
    "maintenance:ncu:minor:u": "npm run maintenance:ncu -- --target minor --upgrade",
    "maintenance:ncu:patch": "npm run maintenance:ncu -- --target patch",
    "maintenance:ncu:patch:u": "npm run maintenance:ncu -- --target patch --upgrade"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "axios": "^1.15.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.5",
    "viem": "2.38.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "rimraf": "^6.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3"
  }
}
