{
  "name": "edc-asset-agreement-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "eslint .",
    "clean": "rimraf dist/* --glob",
    "maintenance:ncu:install": "npm install -g npm-check-updates",
    "maintenance:ncu": "ncu --enginesNode",
    "maintenance:ncu:u": "npm run maintenance:ncu -- --upgrade",
    "maintenance:ncu:minor": "npm run maintenance:ncu -- --target minor",
    "maintenance:ncu:minor:u": "npm run maintenance:ncu -- --target minor --upgrade",
    "maintenance:ncu:patch": "npm run maintenance:ncu -- --target patch",
    "maintenance:ncu:patch:u": "npm run maintenance:ncu -- --target patch --upgrade"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rainbow-me/rainbowkit": "^2.2.9",
    "@tanstack/react-query": "^5.90.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.552.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "viem": "2.38.3",
    "wagmi": "^2.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.16",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "rimraf": "^6.1.0",
    "tailwindcss": "^4.1.16",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "7.1.12"
  }
}
