{
  "name": "edc-asset-agreement-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "maintenance:ncu:install": "npm install -g npm-check-updates",
    "maintenance:ncu": "ncu --enginesNode",
    "maintenance:ncu:u": "npm run maintenance:ncu -- --upgrade",
    "maintenance:ncu:minor": "npm run maintenance:ncu -- --target minor",
    "maintenance:ncu:minor:u": "npm run maintenance:ncu -- --target minor --upgrade",
    "maintenance:ncu:patch": "npm run maintenance:ncu -- --target patch",
    "maintenance:ncu:patch:u": "npm run maintenance:ncu -- --target patch --upgrade"
  },
  "dependencies": {
    "@eslint/js": "^9.37.0",
    "@rainbow-me/rainbowkit": "^2.2.8",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "globals": "^16.4.0",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.14",
    "typescript-eslint": "^8.46.0",
    "viem": "2.38.0",
    "wagmi": "^2.17.5"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.37.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.1",
    "eslint-plugin-react-refresh": "^0.4.23",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vite": "^7.1.9"
  }
}
